# ============================================
# HomeService 环境变量配置示例
# ============================================
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 替换所有占位值为实际配置
# 3. 不要将 .env 提交到 Git 仓库
# ============================================

# --------------------------------------------
# 数据库配置
# --------------------------------------------
# SQLite（开发环境）
DATABASE_URL="sqlite:///./homeservice.db"

# PostgreSQL（生产环境示例）
# DATABASE_URL="postgresql+psycopg2://username:password@localhost:5432/homeservice"

# --------------------------------------------
# API 安全配置
# --------------------------------------------
# API 认证密钥（至少 32 位随机字符串）
API_SECRET_KEY="your-secure-token-min-32-chars"

# 管理员账户
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password123"

# --------------------------------------------
# LLM 模型配置（通用接口 - 支持多种 Provider）
# --------------------------------------------
# 选择使用的 LLM Provider: claude | openai | qwen | deepseek
LLM_PROVIDER="claude"

# API Key（根据选择的 Provider 设置）
LLM_API_KEY="your-api-key-here"

# API Base URL（OpenAI 兼容接口保持默认）
LLM_BASE_URL="https://api.anthropic.com/v1/"

# 模型名称
LLM_MODEL_NAME="claude-3-5-sonnet-20241022"

# --------------------------------------------
# 各 Provider 专用配置（按需启用）
# --------------------------------------------
# OpenAI
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1/"
# OPENAI_MODEL="gpt-4o"

# DeepSeek
# DEEPSEEK_API_KEY="sk-..."
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1/"
# DEEPSEEK_MODEL="deepseek-chat"

# Qwen（通义千问）
# QWEN_API_KEY="sk-..."
# QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1/"
# QWEN_MODEL="qwen-plus"

# --------------------------------------------
# RAG 配置
# --------------------------------------------
# Embedding 模型
EMBEDDING_MODEL="text-embedding-3-small"

# 向量维度（根据 Embedding 模型调整）
# text-embedding-3-small: 512
# text-embedding-3-large: 1024
# claude-3-5-sonnet: 2048
VECTOR_DIMENSION=1536

# 是否启用 Embedding 缓存
ENABLE_CACHE="true"

# 缓存目录
CACHE_DIR="./storage/cache"

# --------------------------------------------
# 调试与日志配置
# --------------------------------------------
# 是否开启调试模式
DEBUG="false"

# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL="INFO"

# 日志格式: json | text
LOG_FORMAT="json"

# 日志文件路径
LOG_FILE="./logs/app.log"

# --------------------------------------------
# 业务配置
# --------------------------------------------
# 默认服务时长（分钟）
DEFAULT_SERVICE_DURATION=120

# 每日最大预约数（师傅）
MAX_APPOINTMENTS_PER_DAY=8

# 派单权重：skill > distance > availability
MATCHING_WEIGHT_SKILL=0.5
MATCHING_WEIGHT_DISTANCE=0.3
MATCHING_WEIGHT_AVAILABILITY=0.2

# --------------------------------------------
# 前端配置（API 端）
# --------------------------------------------
# 允许的 CORS 域名
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:8080"

# 静态文件路径
STATIC_DIR="./HomeService/static"

# --------------------------------------------
# MCP（Mock Connector Placeholders）配置
# --------------------------------------------
# 当前阶段：所有 MCP 接口为模拟实现
# 说明：MCP 接口预留真实服务接入点，目前返回模拟数据用于演示
# 扩展指南：查看 HomeService/services/mcp_service.py 的 MCPClientInterface

# 地图服务（未来扩展）
# MAP_API_KEY="your-map-api-key"

# 日历服务（未来扩展）
# CALENDAR_CLIENT_ID="your-client-id"
# CALENDAR_CLIENT_SECRET="your-client-secret"

# 通知服务（未来扩展）
# NOTIFICATION_API_KEY="your-notification-key"
